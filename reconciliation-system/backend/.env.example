# ==============================================================================
# Environment Variables (Copy to .env and modify)
# ==============================================================================

# App settings
APP_NAME=Reconciliation System
DEBUG=true

# Database type: sqlite or oracle
DB_TYPE=sqlite

# JWT Secret (change in production!)
SECRET_KEY=your-super-secret-key-change-in-production

# Mock mode for testing (true = use CSV instead of Oracle for B4)
MOCK_MODE=true
