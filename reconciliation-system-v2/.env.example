# ============================================================
# Environment Configuration for Docker Compose
# ============================================================

# ============================================================
# DATABASE CONFIGURATION
# ============================================================

# Database type: 'sqlite' or 'oracle'
DB_TYPE=sqlite

# SQLite Configuration (for development/testing)
# SQLITE_PATH=/app/data/app.db

# Oracle Configuration (for production)
ORACLE_HOST=your-oracle-server.com
ORACLE_PORT=1521
ORACLE_USER=your_username
ORACLE_PASSWORD=your_password
ORACLE_SID=ORCL
# Or use TNS Name:
# ORACLE_DSN=your_tns_name

# ============================================================
# APPLICATION CONFIGURATION
# ============================================================

# Mock mode (use mock data instead of real database)
MOCK_MODE=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8001
API_BASE_URL=http://localhost:8001

# Frontend Configuration
VITE_API_URL=http://localhost:8001/api

# ============================================================
# SECURITY CONFIGURATION
# ============================================================

# JWT Secret Key (change this in production!)
SECRET_KEY=your-super-secret-key-change-in-production

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8001,http://127.0.0.1:3000

# ============================================================
# LOGGING CONFIGURATION
# ============================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Redis Configuration (for caching/sessions)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ============================================================
# FILE UPLOAD CONFIGURATION
# ============================================================

# Max upload file size (in MB)
MAX_UPLOAD_SIZE=100

# Allowed file types
ALLOWED_FILE_TYPES=.csv,.xlsx,.xlsb,.xls

# ============================================================
# NGINX CONFIGURATION (if using Nginx reverse proxy)
# ============================================================

# NGINX_PORT=80
# NGINX_SSL_PORT=443
# NGINX_SERVER_NAME=your-domain.com
